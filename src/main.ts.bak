            <div class="grid grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-zinc-500" for="modelProvider" data-i18n="provider">${t("provider")}</label>
                <select id="modelProvider" class="select-field">
                  <option value="ollama">Ollama</option>
                  <option value="deepseek">DeepSeek</option>
                  <option value="gemini">Gemini</option>
