          <div class="control-group">
            <div class="flex gap-1 mr-2 px-2 border-r border-zinc-800">
              <button id="communityColorButton" class="control-btn active" type="button" data-i18n="theme">主题</button>
              <button id="frequencyColorButton" class="control-btn" type="button" data-i18n="heat">热度</button>
              <button id="kindColorButton" class="control-btn" type="button" data-i18n="category">分类</button>
            </div>
            <div class="flex gap-1">
              <button id="view2dButton" class="control-btn active" type="button">2D</button>
              <button id="view3dButton" class="control-btn" type="button">3D</button>
            </div>
          </div>
        </div>
      </header>

      <div class="flex-1 relative overflow-hidden bg-[#08090a]">
        <div id="graphContainer" class="absolute inset-0"></div>
        
        <!-- Build Progress overlay -->
        <div id="buildProgress" class="progress-overlay" hidden>
          <div class="h-1.5 w-full bg-zinc-800 rounded-full overflow-hidden mb-2">
            <div id="progressFill" class="h-full bg-blue-500 transition-all duration-300 shadow-[0_0_12px_rgba(59,130,246,0.5)]"></div>
          </div>
          <p id="progressText" class="text-[10px] text-center uppercase tracking-tighter text-zinc-400 font-bold">Preparing build...</p>
        </div>
